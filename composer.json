{
    "name": "expanse/task-mcp-php",
    "description": "MCP server exposing TaskWarrior as tools for LLM agents.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "php-mcp/server": "^3.3",
        "symfony/process": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "Expanse\\TaskMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Expanse\\TaskMcp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
